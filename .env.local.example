# Supabase 연결 정보 (Project Settings > API Keys 에서 복사)
# 이 파일을 .env.local 로 복사한 뒤 실제 값으로 채우세요.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# 새 publishable key (sb_publishable_... 접두사). legacy anon 키를 대체합니다. 브라우저 노출 안전.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
